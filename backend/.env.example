# CareerOS — Backend Environment Variables
# Copy this file to .env and fill in your own API keys.

# Groq LLM (https://console.groq.com)
GROQ_API_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Hindsight Memory (https://hindsight.vectorize.io)
HINDSIGHT_API_KEY=
HINDSIGHT_URL=https://api.hindsight.vectorize.io

# AgentMail — email API for the daily digest (https://agentmail.to)
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
