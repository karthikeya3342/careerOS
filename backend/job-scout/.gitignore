# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environment ────────────────────────────────────────────
venv/
.venv/
env/

# ── Secrets / local config ─────────────────────────────────────────
.env
.env.*
!.env.example

# ── Playwright / Patchright browser profiles ───────────────────────
